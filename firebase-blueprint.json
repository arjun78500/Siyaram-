{
  "entities": {
    "Car": {
      "title": "Car",
      "description": "A rental car offering.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "number", "description": "Default price per day" },
        "driverPrice": { "type": "number" },
        "selfDrivePrice": { "type": "number" },
        "image": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "fuel": { "type": "string" },
        "seats": { "type": "number" },
        "transmission": { "type": "string" },
        "isFeatured": { "type": "boolean" },
        "isAvailable": { "type": "boolean" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["name", "price", "createdAt"]
    },
    "Booking": {
      "title": "Booking",
      "description": "A request to book a car.",
      "type": "object",
      "properties": {
        "customerName": { "type": "string" },
        "phone": { "type": "string" },
        "pickupLocation": { "type": "string" },
        "dropLocation": { "type": "string" },
        "carId": { "type": "string" },
        "pickupDate": { "type": "string" },
        "duration": { "type": "number" },
        "type": { "type": "string", "enum": ["Self Drive", "With Driver"] },
        "note": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "completed", "cancelled"] },
        "bookingId": { "type": "string" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["customerName", "phone", "carId", "pickupDate", "duration", "type", "status", "createdAt"]
    },
    "Setting": {
      "title": "Setting",
      "description": "Global settings for the website.",
      "type": "object",
      "properties": {
        "mainContact": { "type": "string" },
        "secondaryContact": { "type": "string" },
        "whatsapp": { "type": "string" },
        "aboutText": { "type": "string" },
        "ownerPhoto": { "type": "string" },
        "heroVideo": { "type": "string" },
        "address": { "type": "string" },
        "updatedAt": { "type": "number" }
      }
    }
  },
  "firestore": {
    "cars": {
      "schema": "Car",
      "description": "List of available cars."
    },
    "bookings": {
      "schema": "Booking",
      "description": "User booking requests."
    },
    "settings": {
      "schema": "Setting",
      "description": "Global configuration settings managed by admin."
    }
  }
}
